<mujoco model="fr3">
  <compiler angle="radian" meshdir="panda"/>

  <option integrator="implicitfast"/>

  <default>
    <default class="fr3">
      <joint armature="0.1" damping="1"/>
      <default class="visual">
        <geom group="2" contype="0" conaffinity="0"/>
      </default>
      <site size="0.005" rgba="0.2 0.8 1 0.8" group="4"/>
    </default>
  </default>

  <asset>
    <material name="black" rgba="0.15 0.15 0.15 1"/>
    <material name="white" rgba="0.92 0.92 0.92 1"/>
    <material name="red" rgba="0.82 0.18 0.14 1"/>
    <material name="gray" rgba="0.65 0.65 0.68 1"/>
    <material name="button_green" rgba="0.10 0.57 0.10 1"/>
    <material name="button_red" rgba="0.52 0.01 0.01 1"/>
    <material name="button_blue" rgba="0.10 0.40 0.80 1"/>
    <mesh name="link0_0_vis" file="link0_0.obj"/>
    <mesh name="link0_1_vis" file="link0_1.obj"/>
    <mesh name="link0_2_vis" file="link0_2.obj"/>
    <mesh name="link0_3_vis" file="link0_3.obj"/>
    <mesh name="link0_4_vis" file="link0_4.obj"/>
    <mesh name="link0_5_vis" file="link0_5.obj"/>
    <mesh name="link0_6_vis" file="link0_6.obj"/>
    <mesh name="link1_vis" file="link1.obj"/>
    <mesh name="link2_vis" file="link2.obj"/>
    <mesh name="link3_0_vis" file="link3_0.obj"/>
    <mesh name="link3_1_vis" file="link3_1.obj"/>
    <mesh name="link4_0_vis" file="link4_0.obj"/>
    <mesh name="link4_1_vis" file="link4_1.obj"/>
    <mesh name="link5_0_vis" file="link5_0.obj"/>
    <mesh name="link5_1_vis" file="link5_1.obj"/>
    <mesh name="link5_2_vis" file="link5_2.obj"/>
    <mesh name="link6_0_vis" file="link6_0.obj"/>
    <mesh name="link6_1_vis" file="link6_1.obj"/>
    <mesh name="link6_2_vis" file="link6_2.obj"/>
    <mesh name="link6_3_vis" file="link6_3.obj"/>
    <mesh name="link6_4_vis" file="link6_4.obj"/>
    <mesh name="link6_5_vis" file="link6_5.obj"/>
    <mesh name="link6_6_vis" file="link6_6.obj"/>
    <mesh name="link6_7_vis" file="link6_7.obj"/>
    <mesh name="link7_0_vis" file="link7_0.obj"/>
    <mesh name="link7_1_vis" file="link7_1.obj"/>
    <mesh name="link7_2_vis" file="link7_2.obj"/>
    <mesh name="link7_3_vis" file="link7_3.obj"/>
    <texture name="tex_ground" type="2d" builtin="checker" width="512" height="512"/>
    <material name="groundplane" texture="tex_ground" texrepeat="5 5" reflectance="0.2"/>
  </asset>

  <worldbody>
    <light pos="0 0 1.5" dir="0 0 -1" directional="true"/>
    <geom name="floor" size="0 0 0.05" pos="0 0 0" type="plane" material="groundplane" friction="1 0.005 0.0001" />


    <body name="fr3_link0">
      <geom class="visual" type="mesh" mesh="link0_0_vis" material="black"/>
      <geom class="visual" type="mesh" mesh="link0_1_vis" material="white"/>
      <geom class="visual" type="mesh" mesh="link0_2_vis" material="white"/>
      <geom class="visual" type="mesh" mesh="link0_3_vis" material="white"/>
      <geom class="visual" type="mesh" mesh="link0_4_vis" material="white"/>
      <geom class="visual" type="mesh" mesh="link0_5_vis" material="red"/>
      <geom class="visual" type="mesh" mesh="link0_6_vis" material="black"/>

      <body name="link1" pos="0 0 0.333">
        <inertial pos="0 0 -0.07" mass="4" diaginertia="0.3 0.3 0.3"/>
        <joint name="joint1" pos="0 0 0" axis="0 0 1"
               range="-2.7437 2.7437" actuatorfrcrange="-87 87"/>
        <geom class="visual" type="mesh" mesh="link1_vis" material="white"/>

        <body name="link2" quat="0.707107 -0.707107 0 0">
          <inertial pos="0 -0.1 0" mass="3" diaginertia="0.3 0.3 0.3"/>
          <joint name="joint2" pos="0 0 0" axis="0 0 1"
                 range="-1.7837 1.7837" actuatorfrcrange="-87 87"/>
          <geom class="visual" type="mesh" mesh="link2_vis" material="white"/>

          <body name="link3" pos="0 -0.316 0" quat="0.707107 0.707107 0 0">
            <inertial pos="0.04 0 -0.05" mass="3" diaginertia="0.2 0.2 0.2"/>
            <joint name="joint3" pos="0 0 0" axis="0 0 1"
                   range="-2.9007 2.9007" actuatorfrcrange="-87 87"/>
            <geom class="visual" type="mesh" mesh="link3_0_vis" material="white"/>
            <geom class="visual" type="mesh" mesh="link3_1_vis" material="black"/>

            <body name="link4" pos="0.0825 0 0" quat="0.707107 0.707107 0 0">
              <inertial pos="-0.04 0.05 0" mass="3" diaginertia="0.2 0.2 0.2"/>
              <joint name="joint4" pos="0 0 0" axis="0 0 1"
                     range="-3.0421 -0.1518" actuatorfrcrange="-87 87"/>
              <geom class="visual" type="mesh" mesh="link4_0_vis" material="white"/>
              <geom class="visual" type="mesh" mesh="link4_1_vis" material="black"/>

              <body name="link5" pos="-0.0825 0.384 0" quat="0.707107 -0.707107 0 0">
                <inertial pos="0 0 -0.15" mass="3" diaginertia="0.2 0.2 0.2"/>
                <joint name="joint5" pos="0 0 0" axis="0 0 1"
                       range="-2.8065 2.8065" actuatorfrcrange="-12 12"/>
                <geom class="visual" type="mesh" mesh="link5_0_vis" material="white"/>
                <geom class="visual" type="mesh" mesh="link5_1_vis" material="white"/>
                <geom class="visual" type="mesh" mesh="link5_2_vis" material="black"/>

                <body name="link6" quat="0.707107 0.707107 0 0">
                  <inertial pos="0.06 0 0" mass="2" diaginertia="0.1 0.1 0.1"/>
                  <joint name="joint6" pos="0 0 0" axis="0 0 1"
                         range="0.5445 4.5169" actuatorfrcrange="-12 12"/>
                  <geom class="visual" type="mesh" mesh="link6_0_vis" material="button_green"/>
                  <geom class="visual" type="mesh" mesh="link6_1_vis" material="white"/>
                  <geom class="visual" type="mesh" mesh="link6_2_vis" material="white"/>
                  <geom class="visual" type="mesh" mesh="link6_3_vis" material="gray"/>
                  <geom class="visual" type="mesh" mesh="link6_4_vis" material="button_red"/>
                  <geom class="visual" type="mesh" mesh="link6_5_vis" material="white"/>
                  <geom class="visual" type="mesh" mesh="link6_6_vis" material="black"/>
                  <geom class="visual" type="mesh" mesh="link6_7_vis" material="button_blue"/>

                  <body name="link7" pos="0.088 0 0" quat="0.707107 0.707107 0 0">
                    <inertial pos="0 0 0.1" mass="1" diaginertia="0.1 0.1 0.1"/>
                    <joint name="joint7" pos="0 0 0" axis="0 0 1"
                           range="-3.0159 3.0159" actuatorfrcrange="-12 12"/>
                    <geom class="visual" type="mesh" mesh="link7_0_vis" material="black"/>
                    <geom class="visual" type="mesh" mesh="link7_1_vis" material="white"/>
                    <geom class="visual" type="mesh" mesh="link7_2_vis" material="white"/>
                    <geom class="visual" type="mesh" mesh="link7_3_vis" material="black"/>
                  </body>
                </body>
              </body>
            </body>
          </body>
        </body>
      </body>
    </body>
  </worldbody>

  <actuator>
    <motor class="fr3" name="joint1" joint="joint1" ctrllimited="true" ctrlrange="-87 87"/>
    <motor class="fr3" name="joint2" joint="joint2" ctrllimited="true" ctrlrange="-87 87"/>
    <motor class="fr3" name="joint3" joint="joint3" ctrllimited="true" ctrlrange="-87 87"/>
    <motor class="fr3" name="joint4" joint="joint4" ctrllimited="true" ctrlrange="-87 87"/>
    <motor class="fr3" name="joint5" joint="joint5" ctrllimited="true" ctrlrange="-12 12"/>
    <motor class="fr3" name="joint6" joint="joint6" ctrllimited="true" ctrlrange="-12 12"/>
    <motor class="fr3" name="joint7" joint="joint7" ctrllimited="true" ctrlrange="-12 12"/>
  </actuator>

  <keyframe>
    <key name="home" qpos="0.746 -0.38 0.85 -2.71 0.48 2.385 1.1696"/>
  </keyframe>
</mujoco>
